PROJECT_NAME=ZT-SDX
ENVIRONMENT=development

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=ztsdx
POSTGRES_USER=ztadmin
POSTGRES_PASSWORD=ztpassword

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379

# ── MinIO (ML model storage) ──────────────────────────────────────────────────
MINIO_HOST=minio
MINIO_PORT=9000
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=password123
MINIO_BUCKET=zt-files

# ── JWT (must match auth-service) ─────────────────────────────────────────────
JWT_SECRET=replace_this
JWT_ALGORITHM=HS256

# ── Inter-service URLs ────────────────────────────────────────────────────────
AUDIT_URL=http://audit-service:8000
ALERT_URL=http://alert-service:8000

# ── Risk thresholds ───────────────────────────────────────────────────────────
RISK_MFA_THRESHOLD=30
RISK_DENY_THRESHOLD=60
RISK_LOCK_THRESHOLD=85

# ── Scoring weights (must sum to 1.0) ─────────────────────────────────────────
RULE_WEIGHT=0.6
ML_WEIGHT=0.4
